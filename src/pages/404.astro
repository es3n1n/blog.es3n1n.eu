---
import Layout from '../layouts/Layout.astro'

const title = '404 - not found'
const description = "this page doesn't exist (yet)"
---

<Layout title={title} description={description}>
  <a slot='nav' href='/'>[index]</a>

  <p>looks like you found a dead link.</p>
  <p>try one of these instead:</p>
  <ul class='post-list'>
    <li class='post-item'><a href='/'>home</a></li>
    <li class='post-item'><a href='/rss.xml'>rss feed</a></li>
  </ul>

  <div class='ascii-sep'></div>
  <p>
    if you think this is a mistake, ping me on <a
      href='https://es3n1n.eu/'
      target='_blank'
      rel='noopener noreferrer'>contacts</a
    >.
  </p>
</Layout>
