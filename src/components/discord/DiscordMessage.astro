---
interface Props {
  time: string
  user: string
  color?: string
  badge?: string
  badgeIcon?: string
  fullTime?: string
  cont?: boolean
}

const {
  time,
  user,
  color = '#f2f3f5',
  badge,
  badgeIcon,
  fullTime,
  cont,
} = Astro.props
---

<div class:list={['dc-msg', { cont }]}>
  <span class='dc-time' title={fullTime ?? ''}>{time}</span>
  <div class='dc-body'>
    <span class='dc-user' style={`color: ${color}`}>{user}</span>
    {
      badge && (
        <span class='dc-tag'>
          {badgeIcon && (
            <img
              class='dc-tag-icon'
              src={badgeIcon}
              alt=''
              width='12'
              height='12'
            />
          )}
          <span class='dc-tag-text'>{badge}</span>
        </span>
      )
    }
    <slot />
  </div>
</div>

<style>
  .dc-msg {
    display: grid;
    grid-template-columns: 3rem 1fr;
    column-gap: 0.5rem;
    padding: 0.1rem 1rem 0.1rem 0.75rem;
  }
  .dc-msg:hover {
    background: rgba(255, 255, 255, 0.04);
  }
  .dc-msg.cont .dc-time {
    visibility: hidden;
  }
  .dc-msg.cont:hover .dc-time {
    visibility: visible;
  }
  .dc-time {
    color: #888991;
    font-size: 11px;
    font-weight: 500;
    line-height: 22px;
    text-align: right;
    white-space: nowrap;
    user-select: none;
  }
  .dc-body {
    min-width: 0;
    overflow-wrap: anywhere;
  }
  .dc-user {
    font-weight: 500;
    margin-right: 0.25rem;
  }
  .dc-user:hover {
    text-decoration: underline;
    cursor: pointer;
  }
  .dc-tag {
    display: inline-flex;
    align-items: center;
    margin: -2px 0.25rem 0 2px;
    padding: 0 4px;
    border-radius: 4px;
    background: rgba(151, 151, 159, 0.24);
    color: #dbdee1;
    font-size: 12px;
    font-weight: 600;
    line-height: 1.3;
    vertical-align: middle;
    white-space: nowrap;
  }
  .dc-body :global(p) {
    display: inline;
    margin: 0;
  }
  .dc-body :global(a) {
    color: #00a8fc;
    text-decoration: none;
  }
  .dc-body :global(a:hover) {
    text-decoration: underline;
  }
  .dc-body :global(img),
  .dc-body :global(video) {
    display: block;
    max-width: 100%;
    max-height: 350px;
    width: auto;
    margin: 0.25rem 0;
    border-radius: 0.5rem;
  }
  .dc-tag .dc-tag-icon {
    display: inline-block;
    width: 12px;
    height: 12px;
    max-height: none;
    margin: 0 2px 0 0;
    border-radius: 0;
    vertical-align: middle;
  }
  .dc-body :global(pre) {
    margin: 0.25rem 0;
    padding: 0.5rem 0.6rem;
    border: 1px solid #1e1f22;
    border-radius: 0.3rem;
    background: #2b2d31;
    font-family: Consolas, 'Courier New', monospace;
    font-size: 0.85em;
    line-height: 1.3;
    overflow-x: auto;
  }
</style>
